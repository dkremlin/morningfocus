# ─────────────────────────────────────────────────────────────
# MorningFocus CLI — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you want to change.
# All variables are optional — defaults are shown in comments.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────


# ── Storage ──────────────────────────────────────────────────
# Where tasks.md is stored.
# Resolution order: this var → $XDG_DATA_HOME/morningfocus/ → ~/morningfocus/data/
#
# MORNINGFOCUS_DATA_DIR=/path/to/your/data/dir


# ── Notifications (notify.py / cron) ─────────────────────────
# Title shown in the desktop notification.
# Default: "Morning Focus Briefing"
#
# MORNINGFOCUS_NOTIFY_TITLE=Morning Focus Briefing

# Fallback log file path (used when desktop notification fails).
# Default: ~/.local/share/morningfocus/notify.log
#
# MORNINGFOCUS_NOTIFY_LOG=/path/to/notify.log


# ── Briefing ─────────────────────────────────────────────────
# Default output format for `mf brief`: "rich" or "json"
# Default: rich
#
# MORNINGFOCUS_BRIEF_FORMAT=rich


# ── Development ──────────────────────────────────────────────
# Set to "1" to enable debug-level logging (duplicate tag warnings, etc.)
# Default: 0
#
# MORNINGFOCUS_DEBUG=0
