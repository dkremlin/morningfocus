# ─────────────────────────────────────────────────────────────
# MorningFocus Web — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you want to change.
# All variables are optional — defaults are shown in comments.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────


# ── Database ─────────────────────────────────────────────────
# Full SQLAlchemy connection URL.
# Default: sqlite:///./data/tasks.db  (local SQLite file)
#
# SQLite (default — local dev only, data is lost on Vercel):
# MORNINGFOCUS_DB=sqlite:///./data/tasks.db
#
# Supabase PostgreSQL (copy from Supabase → Settings → Database → URI):
# MORNINGFOCUS_DB=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres
#
# MySQL / MariaDB:
# MORNINGFOCUS_DB=mysql+pymysql://user:password@localhost:3306/morningfocus


# ── Server ───────────────────────────────────────────────────
# Host and port for the web server.
# Default: 127.0.0.1:9000
#
# HOST=127.0.0.1
# PORT=9000

# Set to "true" to allow connections from other devices on your network.
# MORNINGFOCUS_PUBLIC=false


# ── Supabase Auth (required for login to work) ───────────────
# Get these from your Supabase project → Settings → API
#
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...


# ── Security (for future deployment) ─────────────────────────
# Secret key used to sign sessions / tokens.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
#
# SECRET_KEY=change-me-before-deploying

# Allowed origins for CORS (comma-separated).
# Default: http://localhost:9000
#
# CORS_ORIGINS=http://localhost:9000,https://yourdomain.com


# ── Development ──────────────────────────────────────────────
# Enable auto-reload and debug logging.
# Default: false
#
# DEBUG=false
